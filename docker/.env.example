# Mindwtr Cloud auth token (used by both cloud server and ai-service)
MINDWTR_CLOUD_AUTH_TOKENS=your-secret-token-here

# Telegram Bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# LLM provider (OpenAI-compatible, e.g. 9Router)
LLM_BASE_URL=http://your-llm-proxy/v1
LLM_API_KEY=sk-your-llm-api-key
LLM_MODEL=cc/claude-opus-4-6

# Slack (optional) — self-created Slack App with Socket Mode
# https://api.slack.com/apps → Create New App → Socket Mode → enable
# SLACK_APP_TOKEN=xapp-...
# SLACK_BOT_TOKEN=xoxb-...

# Notion (optional) — self-created Internal Integration
# https://www.notion.so/my-integrations → New integration
# Share target database with the integration
# NOTION_API_KEY=secret_...
# NOTION_DATABASE_ID=...
# NOTION_POLL_INTERVAL_MS=300000

# HTTP capture endpoint (optional) — used by desktop capture-agent
# Set to enable POST /v1/capture; pick a long random token.
# HTTP_AUTH_TOKEN=
# HTTP_PORT=3030
