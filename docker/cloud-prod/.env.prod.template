# Production env file for the Hetzner VPS deployment.
# Copy to .env.prod on the VPS at /opt/gtd/.env.prod and fill in values.
# Permissions: chmod 600 (only root reads).

# ────────────────────────────────────────────────────────────────────────
# Image registry — where to pull builds from. Either:
#   (a) GitHub Container Registry (recommended; CI builds + pushes here)
#       GHCR_OWNER=sudorous   IMAGE_TAG=latest
#   (b) Build locally on the VPS with `docker compose -f compose.prod.yaml
#       build` and use ghcr.io paths that won't resolve — fine for v1.
# ────────────────────────────────────────────────────────────────────────
GHCR_OWNER=sudorous
IMAGE_TAG=latest

# ────────────────────────────────────────────────────────────────────────
# Mindwtr Cloud — task store
# ────────────────────────────────────────────────────────────────────────
# Generate ONE token per device that needs Cloud access (Mac capture-agent,
# phone PWA, second laptop). Comma-separated.
MINDWTR_CLOUD_AUTH_TOKENS=prod-token-CHANGEME-1,prod-token-CHANGEME-2

# CORS origin allowed by mindwtr-cloud. Must match the UI hostname.
MINDWTR_CLOUD_CORS_ORIGIN=https://gtd.kurdy.uk

# ────────────────────────────────────────────────────────────────────────
# AI Service
# ────────────────────────────────────────────────────────────────────────
# Bearer token used by capture-agent + PWA to call /v1/capture, /v1/memory/*.
HTTP_AUTH_TOKEN=prod-http-CHANGEME

# CORS origin for /v1/* routes (PWA needs it).
HTTP_CORS_ORIGINS=https://gtd.kurdy.uk

# Telegram bot token (same one used in dev).
TELEGRAM_BOT_TOKEN=

# TG chat that receives proposal push notifications.
TG_NOTIFY_CHAT_ID=

# Identity anchor for Proposer role disambiguation.
USER_IDENTITY_NAME=Sergey Kurdyuk
USER_IDENTITY_ALIASES=Sergey,Сергей,Серёга,Sergey KTR

# ────────────────────────────────────────────────────────────────────────
# LLM proxy (mindwtr-style 9router)
# ────────────────────────────────────────────────────────────────────────
LLM_BASE_URL=http://ec2-54-183-85-48.us-west-1.compute.amazonaws.com:20128/v1
LLM_API_KEY=
LLM_MODEL=cc/claude-opus-4-6

# ────────────────────────────────────────────────────────────────────────
# OpenAI embeddings
# ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
EMBEDDINGS_MODEL=text-embedding-3-small

# ────────────────────────────────────────────────────────────────────────
# Optional channels — leave empty if not used
# ────────────────────────────────────────────────────────────────────────
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ────────────────────────────────────────────────────────────────────────
# Cloudflare Tunnel
# ────────────────────────────────────────────────────────────────────────
# Generated in Cloudflare Zero Trust dashboard:
#   Networks → Tunnels → Create a tunnel → "gtd-prod" → copy the token.
# Routes (configured in same dashboard, not here):
#   gtd.kurdy.uk      → http://mindwtr-app:5173   (or whatever port the
#                                                   image exposes — check
#                                                   docker/app/Dockerfile)
#   api.gtd.kurdy.uk  → http://mindwtr-cloud:8787
#   ai.gtd.kurdy.uk   → http://ai-service:3030
CLOUDFLARE_TUNNEL_TOKEN=

# ────────────────────────────────────────────────────────────────────────
# Storage paths (rarely changed)
# ────────────────────────────────────────────────────────────────────────
GTD_DATA_ROOT=/opt/gtd

# ────────────────────────────────────────────────────────────────────────
# Proactive runner cadence (default 6h)
# ────────────────────────────────────────────────────────────────────────
PROACTIVE_INTERVAL_MS=21600000

# Context Store TTL (default 7 days)
CONTEXT_STORE_TTL_DAYS=7
