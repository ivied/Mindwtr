    "express-rate-limit": "8.3.1",
    "flatted": "3.4.2",
    "node-forge": "1.4.0",
    "path-to-regexp": "8.4.0",
    "picomatch": "4.0.4",
    "tar": "7.5.11",
    "undici": "6.24.1",
    "yaml": "2.8.3",
    "@eslint/eslintrc": {
      "ajv": "6.14.0"
    },
    "eslint": {
      "ajv": "6.14.0"
    }
  },
  "resolutions": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "minimatch": "10.2.3",
    "rollup": "4.59.0",
    "brace-expansion": "5.0.5",
    "@isaacs/brace-expansion": "5.0.1",
    "esbuild": "0.25.12",
    "hono": "4.12.8",
    "@hono/node-server": "1.19.11",
    "express-rate-limit": "8.3.1",
    "flatted": "3.4.2",
    "lodash-es": "4.17.23",
    "node-forge": "1.4.0",
    "path-to-regexp": "8.4.0",
    "picomatch": "4.0.4",
    "qs": "6.15.0",
    "tar": "7.5.11",
    "undici": "6.24.1",
    "yaml": "2.8.3"
  },
  "scripts": {
    "desktop:dev": "bun run --filter mindwtr dev",
    "desktop:web": "bun run --filter mindwtr dev:vite",
    "desktop:build": "bun run --filter mindwtr build",
    "desktop:web:build": "bun run --filter mindwtr build:vite",
    "test": "bun run --filter @mindwtr/core test && bun run --filter mindwtr test && bun run --filter mindwtr-cloud test",
    "test:e2e": "playwright test",
    "ai:dev": "bun run --filter ai-service dev",
    "mindwtr:cli": "bun run scripts/mindwtr-cli.ts --",
    "mindwtr:api": "bun run scripts/mindwtr-api.ts --",
    "mindwtr:mcp": "bun run --filter mindwtr-mcp-server dev --",
    "set-version": "bun run scripts/set-version.ts",
    "dev": "bun run --filter mindwtr-cloud dev & bun run --filter ai-service dev"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.39.1"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "version": "0.1.0"
}
